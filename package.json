{
  "name": "@console-one/multimap",
  "version": "0.2.1",
  "description": "Minimal Map<K, V[]>, Map<K, Set<V>>, and Map<K, Heap<V>> collections with merge, combine, and fromList constructors.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/console-one/multimap.git"
  },
  "bugs": {
    "url": "https://github.com/console-one/multimap/issues"
  },
  "homepage": "https://github.com/console-one/multimap#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "multimap",
    "collections",
    "map",
    "heap",
    "priority-queue"
  ],
  "author": "Andrew Chalmers",
  "license": "MIT",
  "dependencies": {
    "heap-js": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
